rules_version = '2';

// Example security rules for HUB Chat's Firestore data model.
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    function isAdmin(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.admins;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && isMember(chatId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isMember(chatId));
      allow delete: if isSignedIn() && isAdmin(chatId);

      match /messages/{messageId} {
        allow read: if isSignedIn() && isMember(chatId);
        allow create: if isSignedIn() && isMember(chatId) && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }

      match /typing/{userId} {
        allow read: if isSignedIn() && isMember(chatId);
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn(); // allows view-count increments from any signed-in viewer
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
  }
}
